# Copia este archivo como ".env" (o configura estas variables en Vercel:
# Project Settings -> Environment Variables) y rellena con TUS valores de Supabase.
#
# Los encuentras en: Supabase -> Project Settings -> API
#   - Project URL        -> VITE_SUPABASE_URL
#   - anon / public key   -> VITE_SUPABASE_ANON_KEY
#
# IMPORTANTE: la "anon key" es pública (va en el navegador). NUNCA pongas aquí
# la "service_role key".

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI
